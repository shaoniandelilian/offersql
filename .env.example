# 运行环境
NODE_ENV=development

# 后端服务端口
PORT=3001

# 数据库配置
# 可选: sqlite | mysql | postgres
DB_TYPE=sqlite

# SQLite 配置（开发环境）
DB_PATH=./data/sql-practice.db

# MySQL / PostgreSQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sql_practice
DB_USER=root
DB_PASSWORD=your-password

# 贡献题目测试库（不填则默认复用上面的 MySQL 实例/账号）
CONTRIB_TEST_DB_HOST=
CONTRIB_TEST_DB_PORT=
CONTRIB_TEST_DB_USER=
CONTRIB_TEST_DB_PASSWORD=
CONTRIB_TEST_DB_PREFIX=offersql_test_c_

# 查询限制
QUERY_TIMEOUT=30000
MAX_ROWS=1000

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
RESET_CODE_SECRET=your-reset-code-secret-change-in-production

# 短信验证码发送（找回密码）
# mock: 开发环境模拟发送（日志输出验证码）
# http: 调用自定义短信网关（POST JSON: {scene, phone, code}）
# aliyun: 阿里云短信（官方 SDK）
SMS_MODE=mock
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# 邮箱验证码发送（找回密码）
# mock: 开发环境模拟发送（日志输出验证码）
# smtp: 通过 SMTP 发邮件（QQ邮箱可用）
EMAIL_MODE=mock
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_NAME=OfferSQL

# 登录账号（演示环境）
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
# 多账号配置（优先于 AUTH_USERNAME/AUTH_PASSWORD）
AUTH_USERS_JSON=[{"username":"admin","password":"admin123"},{"username":"tester","password":"tester123"}]

# Kimi（Moonshot）配置
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5
KIMI_BASE_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_TIMEOUT_MS=45000

# 日志级别
LOG_LEVEL=info

# 代理与地域访问控制
# TRUST_PROXY=true: 如果服务在 Nginx/网关后面，读取 X-Forwarded-For 作为客户端 IP
TRUST_PROXY=false
# GEO_CN_ONLY_ENABLED=true: 仅允许中国 IP 访问（本机/内网默认放行）
GEO_CN_ONLY_ENABLED=false
# 地理库无法识别 IP 时是否允许访问
GEO_CN_ONLY_ALLOW_UNKNOWN=false
# 生效路径（逗号分隔），默认只限制登录相关接口
GEO_CN_ONLY_PATHS=/api/auth/login,/api/auth/guest-login
